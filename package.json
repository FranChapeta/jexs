{
  "private": true,
  "workspaces": ["core", "physics", "client", "gl", "server", "mcp"],
  "devDependencies": {
    "typescript": "^5.3.0",
    "esbuild": "^0.24.0",
    "prettier": "^3.8.1"
  },
  "scripts": {
    "build": "tsc -b core physics client gl server mcp",
    "build:browser": "esbuild client=client/src/index.ts sw=client/src/sw.ts --bundle --format=esm --splitting --outdir=client/dist/browser --entry-names=[name] --chunk-names=chunks/[hash] --minify --sourcemap --target=es2022"
  }
}
